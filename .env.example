# Resend API key — get one free at https://resend.com
# Required for the contact form (src/app/api/contact/route.ts) to send emails.
RESEND_API_KEY=re_your_api_key_here

# Optional — overrides the default recipient (visualcontentsolution@gmail.com)
# CONTACT_FORM_RECIPIENT=visualcontentsolution@gmail.com

# Optional — overrides the "from" address shown in the email.
# Must be a domain you've verified in Resend, otherwise leave as the default
# onboarding@resend.dev sender (works immediately, no domain verification needed).
# CONTACT_FORM_FROM=Visual Content Solution <hello@yourdomain.com>
